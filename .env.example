# Copy to .env for local development. Never commit a real .env.
NODE_ENV=development
LOG_LEVEL=debug

# HTTP
HOST=0.0.0.0
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://aeg:aeg@localhost:5432/aeg

# Redis (BullMQ + rate limiting)
REDIS_URL=redis://localhost:6379

# Auth — generate strong values for any non-local environment
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Rate limiting (requests per window)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
